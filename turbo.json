{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalDependencies": ["tsconfig.base.json", ".npmrc"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "generated/**", "package.json", "tsconfig.json"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "generated/**", "package.json", "tsconfig.json"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "codegen": {
      "inputs": ["openapi/**", "schemas/**"],
      "outputs": ["generated/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
