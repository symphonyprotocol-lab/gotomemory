{
  "name": "gotomemory",
  "version": "0.0.0",
  "private": true,
  "description": "Cross-platform Memory Control Plane monorepo. See specs/.",
  "type": "module",
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "dev": "turbo run dev",
    "codegen": "turbo run codegen",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "boundaries": "depcruise apps packages --config tooling/dependency-cruiser.cjs",
    "check": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run boundaries",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "prettier": "@gotomemory/config-ts/prettier",
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@gotomemory/config-ts": "workspace:*",
    "@types/node": "^22.9.0",
    "dependency-cruiser": "^16.5.0",
    "eslint": "^9.13.0",
    "prettier": "^3.3.0",
    "tsx": "^4.19.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
