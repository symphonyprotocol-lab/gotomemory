{
  "name": "@gotomemory/contracts",
  "version": "0.0.0",
  "private": true,
  "description": "Single source of truth for the gotomemory API (§9) and data model (§8): OpenAPI + generated types.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./openapi.yaml": "./openapi/openapi.yaml"
  },
  "files": [
    "dist",
    "openapi",
    "generated"
  ],
  "scripts": {
    "codegen": "openapi-typescript openapi/openapi.yaml -o generated/openapi.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "openapi-typescript": "^7.0.0",
    "typescript": "^5.6.0"
  }
}
