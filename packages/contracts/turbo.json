{
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "generated/**", "package.json", "tsconfig.json"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "generated/**", "package.json", "tsconfig.json"]
    },
    "codegen": {
      "inputs": ["openapi/**"],
      "outputs": ["generated/**"]
    }
  }
}
