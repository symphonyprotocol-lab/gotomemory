{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gotomemory.dev/schemas/shared-conversation.schema.json",
  "title": "SharedConversation",
  "type": "object",
  "required": [
    "id",
    "user_id",
    "slug",
    "title",
    "messages",
    "visibility",
    "status",
    "view_count",
    "created_at"
  ],
  "properties": {
    "id": { "type": "string" },
    "user_id": { "type": "string" },
    "slug": { "type": "string", "minLength": 22 },
    "title": { "type": "string", "minLength": 1 },
    "source_platform": { "enum": ["chatgpt", "claude", "gemini"] },
    "messages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role", "content"],
        "properties": {
          "role": { "enum": ["user", "assistant"] },
          "content": { "type": "string" }
        }
      }
    },
    "visibility": { "enum": ["public", "password"] },
    "status": { "enum": ["active", "expired", "deleted"] },
    "expires_at": { "type": ["string", "null"], "format": "date-time" },
    "view_count": { "type": "integer", "minimum": 0 },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
